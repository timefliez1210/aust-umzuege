# Disable MultiViews to prevent Apache from serving .br/.gz as language variants
# Disable directory slash append to prevent redirect loops on /leistungen, /ratgeber
Options -MultiViews
DirectorySlash Off
AddDefaultCharset UTF-8

RewriteEngine On

# 301 redirects for old/wrong URLs indexed by Google
Redirect 301 /leistungen/haushaltsaufloesungen https://www.aust-umzuege.de/leistungen/haushaltsaufloesung
Redirect 301 /kalkulator https://www.aust-umzuege.de/kostenloses-angebot
Redirect 301 /rechtliches/datenschutz https://www.aust-umzuege.de/datenschutz
Redirect 301 /rechtliches/impressum https://www.aust-umzuege.de/impressum
Redirect 301 /leistungen/malerarbeiten https://www.aust-umzuege.de/leistungen

# Force HTTPS + www in a single redirect (avoids double-hop chain)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.aust-umzuege.de/$1 [R=301,L]

# Remove trailing slash (except root) — redirect to non-slash version
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Admin SPA fallback — serve admin.html for all /admin/* routes
RewriteCond %{REQUEST_URI} ^/admin
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /admin.html [L]

# Serve .html files without extension (works for both files and directories with matching .html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ============================
# Compression (gzip)
# ============================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
</IfModule>

# ============================
# Cache Control
# ============================
<IfModule mod_expires.c>
    ExpiresActive On

    # SvelteKit hashed assets (_app/immutable/) - cache forever (1 year)
    # These filenames contain content hashes, so they auto-bust on changes
    <FilesMatch "^_app/immutable/">
        ExpiresDefault "access plus 1 year"
    </FilesMatch>

    # Images - 6 months
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts - 1 year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # CSS & JS - 1 month (non-hashed files)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"

    # HTML - short cache (content can change)
    ExpiresByType text/html "access plus 1 hour"

    # XML (sitemap) - 1 day
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
</IfModule>

# Immutable cache header for hashed SvelteKit assets
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # _app/immutable assets get aggressive caching
    <If "%{REQUEST_URI} =~ m#^/_app/immutable/#">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </If>

    # Fonts - long cache
    <FilesMatch "\.(woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images - 6 months
    <FilesMatch "\.(webp|jpg|jpeg|png|gif|ico)$">
        Header set Cache-Control "public, max-age=15768000"
    </FilesMatch>

    # HTML pages - short cache with revalidation
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>

# ============================
# Security Headers
# ============================
<IfModule mod_headers.c>
    # HSTS - Force HTTPS for 1 year (start with lower max-age if testing)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

    # CSP - Prevent XSS attacks
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.wkdb-siegel.de; style-src 'self' 'unsafe-inline' https://www.wkdb-siegel.de; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com https://*.tile.openstreetmap.org https://api.aufraeumhelden.com https://www.wkdb-siegel.de; media-src 'self' https://api.aufraeumhelden.com; font-src 'self' https://www.wkdb-siegel.de; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://api.aufraeumhelden.com https://www.wkdb-siegel.de; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

    # X-Frame-Options - Prevent clickjacking
    Header always set X-Frame-Options "DENY"

    # COOP - Isolate window from cross-origin documents
    Header always set Cross-Origin-Opener-Policy "same-origin"

    # Additional security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Error document
ErrorDocument 404 /404.html
